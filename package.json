{
  "name": "arkpad",
  "private": true,
  "version": "1.3.0",
  "description": "A high-performance, modular rich text editor framework built on ProseMirror with a Tiptap-inspired API.",
  "license": "MIT",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:app": "npm run dev -w @arkpad/app",
    "dev": "npm run dev -w @arkpad/app",
    "build": "npm run build -w @arkpad/core && npm run build -w @arkpad/react && npm run build -w @arkpad/app",
    "typecheck": "npm run build -w @arkpad/core && npm run build -w @arkpad/react && npm run typecheck --workspaces",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "check": "npm run typecheck && npm run lint && npm run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
