{
  "name": "@arkpad/react",
  "version": "1.6.12",
  "description": "React components and hooks for the Arkpad rich text editor.",
  "keywords": [
    "react",
    "prosemirror",
    "editor",
    "rich-text",
    "arkpad",
    "headless",
    "modular",
    "component",
    "hooks",
    "tiptap",
    "block-editor",
    "notion-style",
    "blog-editor",
    "rich-text-editor"
  ],
  "author": "ArkCabin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arkcabin/arkpad.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/arkcabin/arkpad/issues"
  },
  "homepage": "https://github.com/arkcabin/arkpad/tree/main/packages/react#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@arkpad/core": "1.6.12",
    "@radix-ui/react-checkbox": "^1.3.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  }
}
