{
  "name": "@arkpad/core",
  "version": "1.6.13",
  "description": "Core engine for the Arkpad rich text editor.",
  "keywords": [
    "prosemirror",
    "editor",
    "rich-text",
    "arkpad",
    "headless",
    "modular",
    "framework",
    "tiptap",
    "block-editor",
    "notion-style",
    "blog-editor",
    "rich-text-editor"
  ],
  "author": "ArkCabin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arkcabin/arkpad.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/arkcabin/arkpad/issues"
  },
  "homepage": "https://github.com/arkcabin/arkpad/tree/main/packages/core#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "nanoid": "^5.0.0",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.4",
    "prosemirror-placeholder": "^1.0.7",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.8",
    "@arkpad/shared": "workspace:*"
  },
  "peerDependencies": {
    "@arkpad/extension-table": "*",
    "@arkpad/extension-marks": "*"
  },
  "devDependencies": {
    "@types/prosemirror-tables": "^0.8.0"
  }
}
